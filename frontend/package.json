{
  "name": "lorapok-localsync",
  "productName": "Lorapok LocalSync",
  "private": true,
  "version": "1.0.15",
  "description": "Secure encrypted communication for your local network",
  "repository": {
    "type": "git",
    "url": "https://github.com/Maijied/Lorapok-LocalSync.git"
  },
  "author": "Mohammad Maizied Hasan Majumder <mdshuvo40@gmail.com>",
  "homepage": "https://Maijied.github.io/Lorapok-LocalSync",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:5173 && electron electron/main.js\"",
    "electron:start": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:5173 && electron electron/main.js\"",
    "electron:build": "npm run build && electron-builder",
    "cap:sync": "npm run build && npx cap sync",
    "cap:icons": "npx @capacitor/assets generate --iconBackgroundColor #050505 --splashBackgroundColor #050505"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "compressorjs": "^1.3.0",
    "crypto-js": "^4.2.0",
    "idb": "^8.0.3",
    "lucide-react": "^1.8.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@eslint/js": "^9.19.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.4.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "vite": "^6.1.0",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.lorapok.localsync",
    "productName": "Lorapok LocalSync",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!node_modules{,/**}",
          "!lorapok.db"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png",
      "artifactName": "Lorapok-LocalSync-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lorapok LocalSync",
      "uninstallDisplayName": "Lorapok LocalSync (Uninstall)"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png",
      "artifactName": "Lorapok-LocalSync-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Communication",
      "icon": "public/icon.png",
      "artifactName": "Lorapok-LocalSync-${version}.${ext}"
    }
  }
}
