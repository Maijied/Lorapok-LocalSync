{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "description": "Secure encrypted communication for your local network",
  "repository": {
    "type": "git",
    "url": "https://github.com/Maijied/Lorapok-LocalSync.git"
  },
  "author": "Maijied",
  "homepage": "https://Maijied.github.io/Lorapok-LocalSync",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:start": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:5173 && electron electron/main.js\"",
    "electron:build": "npm run build && electron-builder",
    "cap:sync": "npm run build && npx cap sync"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "compressorjs": "^1.3.0",
    "crypto-js": "^4.2.0",
    "idb": "^8.0.3",
    "lucide-react": "^1.8.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.9",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.0",
    "cross-env": "^7.0.3"
  },
  "build": {
    "appId": "com.lorapok.localsync",
    "productName": "Lorapok-LocalSync",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "Lorapok-LocalSync-Setup-${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "artifactName": "Lorapok-LocalSync-${version}.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "artifactName": "Lorapok-LocalSync-${version}.${ext}"
    }
  }
}
